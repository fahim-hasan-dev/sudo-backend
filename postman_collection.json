{
  "info": {
    "_postman_id": "sudo-backend-somiti-collection",
    "name": "Sudo Backend - Group, Contribution & Chat API",
    "description": "Postman API Collection for Sudo Backend containing Group, Contribution, and Group Message modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Group Module",
      "item": [
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Family Savings Group\",\n  \"contributionAmount\": 200,\n  \"paymentFrequency\": \"monthly\",\n  \"totalCycles\": 5,\n  \"startDate\": \"2026-08-01T00:00:00.000Z\",\n  \"visibility\": \"public\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/group/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                "create"
              ]
            },
            "description": "Create a new pending savings group. Creator must have completed Stripe connect onboarding."
          },
          "response": []
        },
        {
          "name": "Join Group",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group/join/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                "join",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group to join"
                }
              ]
            },
            "description": "Join an existing pending group. Member must have completed Stripe connect onboarding."
          },
          "response": []
        },
        {
          "name": "Start Group Rotation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group/start/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                "start",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group to start"
                }
              ]
            },
            "description": "Activate the group and generate the cyclic rotation schedule (Only Group Admin can perform this once the group is full)."
          },
          "response": []
        },
        {
          "name": "Get Single Group",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group"
                }
              ]
            },
            "description": "Retrieve comprehensive group configurations, populated member details, current period information, current receiver, and full rotation schedule."
          },
          "response": []
        },
        {
          "name": "Get My Groups",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group/my-groups",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                "my-groups"
              ]
            },
            "description": "Retrieve all groups the authenticated user is a member of, populated with current cycle progress, share total, current cycle index, and next due date."
          },
          "response": []
        },
        {
          "name": "Get All Groups",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group"
              ]
            },
            "description": "Retrieve all groups. If admin, returns both public and private groups. If user, returns only public groups."
          },
          "response": []
        },
        {
          "name": "Pay Period Contribution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group/pay/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                "pay",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group"
                }
              ]
            },
            "description": "Initialize a Stripe Checkout Session to pay contribution for the current active period, splitting commission fee and transferring the remainder to the receiver."
          },
          "response": []
        },
        {
          "name": "Track Payments and Dues",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group/status/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group",
                "status",
                ":id"
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group"
                }
              ]
            },
            "description": "Track the payment history of all members across cycles, identifying paid, unpaid, or overdue status."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Contribution Module",
      "item": [
        {
          "name": "Get User Contribution History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contribution/history?type=all&groupId=",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contribution",
                "history"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "all",
                  "description": "Filter by 'paid', 'received', or 'all' (default)"
                },
                {
                  "key": "groupId",
                  "value": "",
                  "description": "Optional: Filter history for a specific savings group"
                }
              ]
            },
            "description": "Retrieve transaction list of contributions paid or received by the authenticated user."
          },
          "response": []
        },
        {
          "name": "Get User Outstanding Dues",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contribution/outstanding",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "contribution",
                "outstanding"
              ]
            },
            "description": "Retrieve list of current dues and past overdue contributions for the logged-in user across all active groups."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Group Message Module",
      "item": [
        {
          "name": "Get Group Chat History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group-message/:groupId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group-message",
                ":groupId"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group"
                }
              ]
            },
            "description": "Retrieve chat history logs for a specific savings group."
          },
          "response": []
        },
        {
          "name": "Send Group Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello everyone, hope you are doing well!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/group-message/:groupId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group-message",
                ":groupId"
              ],
              "variable": [
                {
                  "key": "groupId",
                  "value": "group_mongodb_id_here",
                  "description": "MongoDB ID of the target group"
                }
              ]
            },
            "description": "Send a chat message to the group."
          },
          "response": []
        },
        {
          "name": "Update Group Message",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Hello everyone, hope you are doing well! (Edited)\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/group-message/:messageId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group-message",
                ":messageId"
              ],
              "variable": [
                {
                  "key": "messageId",
                  "value": "message_mongodb_id_here",
                  "description": "MongoDB ID of the target message to update"
                }
              ]
            },
            "description": "Edit the text of an existing group message (Restricted to message sender)."
          },
          "response": []
        },
        {
          "name": "Delete Group Message",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/group-message/:messageId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "group-message",
                ":messageId"
              ],
              "variable": [
                {
                  "key": "messageId",
                  "value": "message_mongodb_id_here",
                  "description": "MongoDB ID of the target message to delete"
                }
              ]
            },
            "description": "Delete a group message (Restricted to message sender or group admin)."
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5002/api/v1",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "insert_jwt_token_here",
      "type": "string"
    }
  ]
}
