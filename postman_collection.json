        {
          "name": "Didit Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Signature-V2",
                "value": "hex_signature_hash_here",
                "type": "text",
                "description": "HMAC-SHA256 signature generated using Webhook Secret"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"status.updated\",\n  \"id\": \"evt_123456\",\n  \"session_id\": \"sess_example_123\",\n  \"session_kind\": \"user\",\n  \"status\": \"Approved\",\n  \"vendor_data\": \"user_mongodb_id_here\",\n  \"timestamp\": \"2026-07-15T12:00:00Z\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/didit-webhook",
              "host": [
                "{{baseUrl}}"
