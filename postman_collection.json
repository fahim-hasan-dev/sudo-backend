        {
          "name": "User Signup",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "fullName",
                  "value": "John Doe",
                  "type": "text",
                  "description": "Full name of the user (Required)"
                },
                {
                  "key": "email",
                  "value": "john.doe@example.com",
                  "type": "text",
                  "description": "Valid email address (Required)"
                },
                {
                  "key": "phoneNumber",
                  "value": "+1234567890",
                  "type": "text",
                  "description": "Valid phone number with country code (Required)"
                },
                {
                  "key": "address",
                  "value": "123 Main Street, New York, NY",
                  "type": "text",
                  "description": "Residential address (Required)"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text",
                  "description": "Password must be at least 6 characters (Required)"
                },
                {
                  "key": "image",
                  "type": "file",
                  "description": "Profile picture image file (Optional)"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup"
              ]
            },
            "description": "Create a new user account using form-data for profile image upload."
